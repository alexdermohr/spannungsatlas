{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "case-export.schema.json",
  "title": "Spannungsatlas Case Export",
  "type": "object",
  "required": ["format", "version", "exportedAt", "appVersion", "cases"],
  "properties": {
    "format": { "const": "spannungsatlas-case-export" },
    "version": { "const": "1.0" },
    "exportedAt": { "type": "string", "format": "date-time" },
    "appVersion": { "type": "string", "minLength": 1 },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["case"],
        "properties": {
          "case": {
            "type": "object",
            "required": ["id", "participants", "context", "observation", "currentReflection", "revisions"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "participants": { "type": "array", "minItems": 1 },
              "context": { "type": "string", "minLength": 1 },
              "observedAt": { "type": "string" },
              "observation": { "type": "object" },
              "currentReflection": { "type": "object" },
              "revisions": { "type": "array" },
              "sources": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["type", "payload", "importedAt"],
                  "properties": {
                    "type": { "type": "string", "minLength": 1 },
                    "payload": {},
                    "importedAt": { "type": "string", "format": "date-time" }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
